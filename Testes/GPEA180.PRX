▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀*/
Static Function RHTamFilial(cFilCnv, cEmp)
Local cNewFil
Local nTamFil

DEFAULT cFilCnv := ""
DEFAULT cEmp	   := cEmpAnt

cNewFil := cFilCnv + Space(12)
nTamFil := FwSizeFilial(cEmp)
cNewFil := Substr(cNewFil, 1, nTamFil )

Return( cNewFil )

