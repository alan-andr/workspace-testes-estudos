▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀
*/
Static Function IntegDef( cXml, nType, cTypeMsg, cVersaoMsg )

Local aRet := {}

aRet:= GPEI180( cXml, nType, cTypeMsg, cVersaoMsg )

	//Restaura Empresa e Filial de Entrada
	If !Empty(__cEmpAnt)
		cEmpAnt	:= __cEmpAnt
		cFilAnt := __cFilAnt
	EndIf

Return aRet

