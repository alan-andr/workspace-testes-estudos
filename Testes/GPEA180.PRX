Static Function GP180DelOk()
Local lDel	:= If(oGetSRA2:aCols[oGetSRA2:oBrowse:nAt,Len(oGetSRA2:aHeader)+1], .F. , .T. )

oGetSRA21:aCols[oGetSRA2:oBrowse:nAt,Len(oGetSRA21:aHeader) + 1 ] := lDel
If( IsBlind(),, oGetSRA21:Refresh() )
Return .T.
